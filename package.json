{
  "name": "launchpad-nextjs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "docker:build": "TAG=$(git rev-parse --short HEAD) docker compose build && docker tag sirily11/draconis-launchpad:$(git rev-parse --short HEAD) sirily11/draconis-launchpad:latest",
    "docker:push": "docker push sirily11/draconis-launchpad:$(git rev-parse --short HEAD) && docker push sirily11/draconis-launchpad:latest",
    "docker:build-push": "bun run docker:build && bun run docker:push",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
